<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto">

    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>
    
    <VerticalStackLayout Spacing="10" Padding="10">
        <Label Text="Novo Produto" 
       HorizontalOptions="Start" 
       Padding="20, 0, 0, 0"
       VerticalOptions="Center" 
       FontSize="25" 
       FontAttributes="Bold" />
        
        <VerticalStackLayout Margin="10" Padding="10, 0, 10, 10">
        <Label Text="Descrição do Produto:" Padding="0, 0, 0, 5"/>
        <Entry x:Name="txt_descricao" WidthRequest="600" HorizontalOptions="Start"/>

        <Label Text="Quantidade:" Padding="0, 15, 0, 5" />
        <Entry x:Name="txt_quantidade" Keyboard="Numeric" WidthRequest="600" HorizontalOptions="Start"/>

        <Label Text="Preço Unitário:" Padding="0, 15, 0, 5"/>
        <Entry x:Name="txt_preco" Keyboard="Numeric" WidthRequest="600" HorizontalOptions="Start"/></VerticalStackLayout>
    </VerticalStackLayout>
</ContentPage>